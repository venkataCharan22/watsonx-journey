{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "build": {
    "env": {
      "BASE_PATH": "/"
    }
  },
  "services": {
    "watsonx-journey": {
      "root": ".",
      "framework": "vite"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "watsonx-journey"
      }
    }
  ]
}
